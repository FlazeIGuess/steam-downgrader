{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "steam-downgrader",
  "version": "0.2.1",
  "identifier": "com.victo.steam-downgrader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Downgrader",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "../steam-helper/publish/steam-helper.exe": "steam-helper.exe"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/FlazeIGuess/steam-downgrader/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwQzAxNDEwNkJCMUIzNDkKUldSSnM3RnJFQlRBWU5ZcG9CaDZ5NzRobDRzZm9IdDBzenNFLy81amRHMFY3dkRQMmt6MjZyRlEK"
    }
  }
}
